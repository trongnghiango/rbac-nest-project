{
    "jsc": {
        "target": "es2021",
        "parser": {
            "syntax": "typescript",
            "decorators": true,
            "dynamicImport": true
        },
        "transform": {
            "legacyDecorator": true,
            "decoratorMetadata": true
        },
        "keepClassNames": true,
        "baseUrl": ".",
        "paths": {
            "@config/*": [
                "src/config/*"
            ],
            "@core/*": [
                "src/core/*"
            ],
            "@database/*": [
                "src/database/*"
            ],
            "@modules/*": [
                "src/modules/*"
            ],
            "@api/*": [
                "src/api/*"
            ]
        }
    },
    "module": {
        "type": "commonjs"
    }
}