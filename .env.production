# Database
DB_HOST=postgres
DB_USERNAME=admin
DB_PASSWORD=MyStrongPassword123
DB_NAME=rbac_prod_db

# Redis
REDIS_HOST=redis

# App
NODE_ENV=production
JWT_SECRET=super_secret_key_for_production
RUN_MIGRATIONS=true

# Dental Paths
DENTAL_UPLOAD_DIR=/app/uploads/dental/temp
DENTAL_OUTPUT_DIR=/app/uploads/dental/converted
RUN_SEEDS=true
DB_PORT=5432
PORT=8080
# Đảm bảo không có DATABASE_URL dư thừa ở đây để entrypoint tự tạo
APP_URL=http://localhost:8080
